#!/usr/bin/env bash
# 저장 — 작업물을 안전하게 보관(커밋+푸시)합니다. 영상(mp4)은 제외, 텍스트만 저장돼요. (D16, PRD 5-5)
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROGRAM_DIR="$ROOT/99_절대_건들지마세요_프로그램파일"

echo "[저장] 작업물을 내 저장소에 안전하게 보관합니다. (푸시 전에 키 유출 검사를 먼저 해요)"

# 대상 스크립트는 구현 완료 상태 — 파일이 없다면 구버전 작업방이므로 복구를 안내
if [ ! -f "$PROGRAM_DIR/scripts/save.mjs" ]; then
  echo ""
  echo "⚠️  프로그램 파일이 없어요 (구버전 작업방으로 보여요)."
  echo "   터미널에 '업데이트' 를 입력해 최신 프로그램을 받은 뒤 다시 시도해 주세요."
  exit 1
fi

exec npm --prefix "$PROGRAM_DIR" run save
