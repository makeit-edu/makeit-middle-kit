#!/usr/bin/env bash
# 음성미리듣기 — 편집기에서 고친 자막의 음성만 다시 만들어 확인합니다. 영상 렌더링은 하지 않아요. (2주차, 선택)
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROGRAM_DIR="$ROOT/99_절대_건들지마세요_프로그램파일"

echo "[음성미리듣기] 바뀐 문장만 음성을 새로 만듭니다. (영상은 만들지 않아요 — 완성영상 폴더도 그대로예요)"
exec node "$PROGRAM_DIR/video-workspace/remotion-ui/scripts/render-editor-timeline.mjs" --voice-only "$@"
