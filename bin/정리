#!/usr/bin/env bash
# 정리 — 완료된 작업의 중간 파일을 지워 저장 공간을 확보합니다. (PRD 5-7, 15GB-month 한도 관리)
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROGRAM_DIR="$ROOT/99_절대_건들지마세요_프로그램파일"

echo "[정리] 끝난 작업의 중간 파일을 청소해 공간을 확보합니다. (완성영상 다운로드 여부를 먼저 물어봐요)"

# 대상 스크립트는 구현 완료 상태 — 파일이 없다면 구버전 작업방이므로 복구를 안내
if [ ! -f "$PROGRAM_DIR/scripts/clean.mjs" ]; then
  echo ""
  echo "⚠️  프로그램 파일이 없어요 (구버전 작업방으로 보여요)."
  echo "   터미널에 '업데이트' 를 입력해 최신 프로그램을 받은 뒤 다시 시도해 주세요."
  exit 1
fi

exec npm --prefix "$PROGRAM_DIR" run clean
