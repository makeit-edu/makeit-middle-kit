# 월부 중급반 Codex 프로젝트 로컬 설정 예시
# 이 파일을 복사해서 .env.local 을 만들고 실제 값을 입력함.
# .env.local 은 절대 공유하지 않음.

# 공통 (수강 코드는 강의 자료실 공지 확인 후, 터미널에서 `키설정`으로 입력)
MAKEIT_MIDDLE_LICENSE=your-course-code
OPENAI_API_KEY=sk-your-openai-api-key

# 1주차: 메킷애센 애드센스 승인 사이트
# 처음에는 사이트 1개만 입력해도 됨. 사이트 2/3은 여러 사이트를 운영할 때만 추가 입력.
ADSENSE_SITE_01_URL=https://example-1.com
ADSENSE_SITE_01_USER=your-admin-id
ADSENSE_SITE_01_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

ADSENSE_SITE_02_URL=https://example-2.com
ADSENSE_SITE_02_USER=your-admin-id
ADSENSE_SITE_02_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

ADSENSE_SITE_03_URL=https://example-3.com
ADSENSE_SITE_03_USER=your-admin-id
ADSENSE_SITE_03_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# 애드센스 승인글 자동화 기본값
ARTICLE_MODEL=gpt-5.4-mini
ARTICLE_MIN_CHARS=3000
DEFAULT_POST_STATUS=draft
ARTICLE_USD_KRW=1543.57527
IMAGE_MODEL=gpt-image-1-mini
IMAGE_QUALITY=low
IMAGE_SIZE=1536x1024
IMAGE_OUTPUT_FORMAT=jpeg

# 예전 단일 워드프레스 구조 호환용
WORDPRESS_URL=https://example.com
WORDPRESS_USER=your-admin-id
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# 2주차: 메킷허브 쇼핑숏폼 자동화
HUB_WORDPRESS_URL=https://example-shop.com
HUB_WORDPRESS_USER=your-admin-id
HUB_WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
ELEVENLABS_API_KEY=your-elevenlabs-api-key

DEFAULT_VIDEO_RATIO=9:16
DEFAULT_EXPORT_FORMAT=mp4
DEFAULT_LANGUAGE=ko
